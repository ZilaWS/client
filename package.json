{
  "$schema": "https://json.schemastore.org/package",
  "name": "zilaws-client",
  "version": "3.0.0",
  "description": "ZilaWS is a blazingly fast and very lightweight library that provides an extremely easy-to-use way to transmit data via websockets between client-side and server-side using eventhandlers and async waiters.",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "umd:main": "dist/umd/index.js",
  "types": "dist/types/index.d.ts",
  "browser": "dist/umd/index.js",
  "scripts": {
    "build": "npm run format:fix && bun run test:bun:all && npm run test:cov-build && npm run format:fix && npm run build:cjs && npm run build:esm && npm run build:umd && npm run build:types",
    "forcebuild": "npm run format:fix && npm run build:cjs && npm run build:esm && npm run build:umd && npm run build:types",
    "build:cjs": "rimraf ./dist/cjs && tsc -p config/tsconfig.cjs.json",
    "build:esm": "rimraf ./dist/esm && tsc -p config/tsconfig.esm.json",
    "build:umd": "rimraf ./dist/umd && webpack --config config/webpack.config.js",
    "build:types": "rimraf ./dist/types && tsc -p config/tsconfig.types.json",
    "clean": "rimraf ./dist/cjs ./dist/esm ./dist/umd ./dist/types",
    "test": "jest --config jest.multi.config.cjs --no-cache --runInBand --verbose",
    "test:cov": "jest --config jest.multi.config.cjs --coverage --no-cache --runInBand --verbose",
    "test:cov-browser-output": "npm run test:cov && start ./coverage/lcov-report/index.html",
    "test:puppeteer": "jest --config jest.multi.config.cjs --selectProjects browser --no-cache --runInBand --verbose",
    "test:puppeteer:bun": "bun test test/puppeteer.test.ts test/cookieSync.puppeteer.test.ts --preload ./test/setup/puppeteer.preload.ts --timeout 30000",
    "test:bun": "bun test test/index.test.ts",
    "test:bun:all": "bun run test:bun && bun run test:puppeteer:bun",
    "test:browser": "bun run test:puppeteer:bun",
    "test:unit": "jest --config jest.multi.config.cjs --selectProjects unit --no-cache --runInBand --verbose",
    "test:cov-build": "jest --config jest.multi.config.cjs --selectProjects unit --coverage --no-cache --runInBand --verbose && jest-coverage-badges-ts --output \"./.coverage-badges\"",
    "test:cov:unit": "jest --config jest.multi.config.cjs --selectProjects unit --coverage --no-cache --runInBand --verbose",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "release": "rimraf ./*.tgz -g && npm run build && node tools/versionManager.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "websocket",
    "client",
    "connection",
    "library",
    "eventhandler",
    "waiter",
    "async",
    "tcp",
    "realtime",
    "browser",
    "node",
    "typescript",
    "events"
  ],
  "author": "warstekhun",
  "license": "MIT",
  "homepage": "https://zilaws.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZilaWS/client.git"
  },
  "bugs": {
    "url": "https://github.com/ZilaWS/client"
  },
  "devDependencies": {
    "@types/bun": "1.3.5",
    "@types/cookie": "^0.6.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.10",
    "@types/puppeteer": "^5.4.7",
    "@types/selenium-webdriver": "^4.1.28",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "jest-coverage-badges-ts": "^0.1.8",
    "jest-environment-puppeteer": "^11.0.0",
    "jest-puppeteer": "^11.0.0",
    "prettier": "^3.3.2",
    "prompt": "^1.3.0",
    "puppeteer": "^24.23.0",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.2.2",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3",
    "vite": "^7.1.9",
    "webpack": "^5.93.0",
    "webpack-cli": "^5.1.4",
    "zilaws-server": "^2.2.0"
  },
  "dependencies": {
    "cookie": "^1.0.2",
    "uuid": "^10.0.0",
    "ws": "^8.18.0"
  }
}
